# Puerto donde se levantará la API NestJS
PORT=3000

# Secreto utilizado para firmar los JWT. Debe ser una cadena larga y segura en producción.
JWT_SECRET=change-me-in-production

# Tiempo de expiración de los tokens emitidos
JWT_EXPIRATION=1h

# Conexión a la base de datos que se configurará más adelante
DATABASE_URL=postgresql://username:password@localhost:5432/opensound
